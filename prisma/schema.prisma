datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model Project {
  id        String   @id @default(cuid())
  name      String
  githubUrl String   @unique
  version   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
