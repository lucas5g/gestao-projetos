datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id        String   @id @default(cuid())
  name      String
  githubUrl String   @unique
  version   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
